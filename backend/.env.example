# Template environment — salin jadi `.env` lalu isi nilai asli.
# JANGAN menaruh rahasia di file ini (file ini ikut dicommit).

# --- Aplikasi ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Database PostgreSQL (Neon/Supabase/lokal) ---
DATABASE_URL="postgresql://user:password@localhost:5432/durent?schema=public"

# --- Auth (Tahap 2) ---
# JWT_SECRET: string acak panjang (mis. 48 byte base64) — WAJIB diganti
JWT_SECRET="ganti-dengan-string-acak-panjang"
JWT_EXPIRES_IN=1d
# Akun staff pertama (role owner) — dibuat oleh `npx prisma db seed`
ADMIN_NAME="Owner DuRent"
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD="password-kuat-anda"
